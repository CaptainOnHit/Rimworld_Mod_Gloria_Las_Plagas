<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<HediffDef ParentName="AddedBodyPartBase">
		<defName>CCDevelopment_LasPlagas_GuadanaHead</defName>
		<label>guadana head</label>
		<description>The Plaga Parasite has Burst through the host's skull.</description>
		<descriptionHyperlinks>
			<GeneDef>CCDevelopment_LasPlagas_Guadana_Head_Gene</GeneDef>
		</descriptionHyperlinks>
		<addedPartProps>
			<partEfficiency>1</partEfficiency>
		</addedPartProps>
		<stages>
			<li>
				  <label>attached</label>
				  <capMods>
						<li>
							<capacity>Talking</capacity>
							<setMax>0</setMax>
						</li>
				  </capMods>
			</li>
		</stages>
	</HediffDef>
	
	<HediffDef ParentName="AddedBodyPartBase">
		<defName>CCDevelopment_LasPlagas_MandibulaHead</defName>
		<label>mandibula head</label>
