	<RecipeDef ParentName="SurgeryFlesh">
		<defName>CCDevelopment_LasPlagas_Surgery_RemoveParasite</defName>
		<label>remove Plaga Parasite</label>
		<description>An attempt to surgically remove the Plaga Parasite from an infected host. The parasite's grip on the nervous system makes a clean extraction nearly impossible. Results are unpredictable and may even cause greater harm.</description>
		<jobString>Removing Plaga Parasite</jobString>
		<workerClass></workerClass>
		<workAmount>3000</workAmount>
		<hideBodyPartNames>true</hideBodyPartNames>
		<targetsBodyPart>false</targetsBodyPart>
		<isViolation>true</isViolation>
		<deathOnFailedSurgeryChance>1</deathOnFailedSurgeryChance>
		<effectWorking>Surgery</effectWorking>
		<surgerySuccessChanceFactor>1.25</surgerySuccessChanceFactor>
		<soundWorking>Recipe_Surgery</soundWorking>
		<recipeUsers>
			<li>Human</li>
		</recipeUsers>
		<ingredients>
			<li>
				<filter>
					<categories>
						<li>Medicine</li>
					</categories>
				</filter>
				<count>2</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<categories>
				<li>Medicine</li>
			</categories>
		</fixedIngredientFilter>
		<workerClass>CCDevelopment.LasPlagas.RecipeWorker_RemoveParasite</workerClass>
	</RecipeDef>

