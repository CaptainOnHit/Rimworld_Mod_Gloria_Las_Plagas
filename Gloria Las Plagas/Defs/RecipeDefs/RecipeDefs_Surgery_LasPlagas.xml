<?xml version="1.0" encoding="utf-8" ?>

<Defs>
	<RecipeDef ParentName="SurgeryFlesh">
		<defName>CCDevelopment_LasPlagas_Surgery_Subordinate</defName>
		<label>las Plagas surgery</label>
		<description>A Plaga Parasite is implanted into the subject's body. It attaches itself to the spine and integrates into the central nervous system, slowly eroding the host's independence.</description>
		<descriptionHyperlinks>
			<HediffDef>CCDevelopment_LasPlagas_Infection_Subordinate</HediffDef>
		</descriptionHyperlinks>
		<researchPrerequisite>MedicineProduction</researchPrerequisite>
		<workerClass>CCDevelopment.LasPlagas.Recipe_AddHediff_PlagaCheck</workerClass>
		<addsHediff>CCDevelopment_LasPlagas_Infection_Subordinate</addsHediff>
		<jobString>Infecting TargetA.</jobString>
		<workAmount>1000</workAmount>
		<hideBodyPartNames>true</hideBodyPartNames>
		<targetsBodyPart>false</targetsBodyPart>
		<isViolation>true</isViolation>
		<deathOnFailedSurgeryChance>0.1</deathOnFailedSurgeryChance>
		<developmentalStageFilter>Adult</developmentalStageFilter> <!-- Las Plagas kills every child -->
		<surgeryOutcomeEffect IsNull="True" /> <!-- Always succeeds -->
		<recipeUsers>
		<li>Human</li>
		</recipeUsers>
		
		<ingredients>
			<li>
				<filter>
					<categories>
						<li>Medicine</li>
					</categories>
				</filter>
				<count>1</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>CCDevelopment_LasPlagas_Embryo</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>CCDevelopment_LasPlagas_Embryo</li>
			</thingDefs>
			<categories>
				<li>Medicine</li>
			</categories>
		</fixedIngredientFilter>
	</RecipeDef>
	
