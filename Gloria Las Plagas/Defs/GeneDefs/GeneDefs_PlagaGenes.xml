	<GeneDef>
		<defName>CCDevelopment_LasPlagas_SuperiorPlaga_Gene</defName>
		<label>superior Plaga</label>
		<description>Plaga Parasites of the superior species allow the host to assume monstrous forms.</description>
		<descriptionHyperlinks>
			<AbilityDef>CCDevelopment_LasPlagas_TransformClaw</AbilityDef>
			<AbilityDef>CCDevelopment_LasPlagas_TransformBlade</AbilityDef>
		</descriptionHyperlinks>
		<geneClass>CCDevelopment.LasPlagas.Gene_Superior</geneClass>
		<iconPath>UI/Icons/Genes/Gene_Superior</iconPath>
		<abilities>
			<li>CCDevelopment_LasPlagas_TransformClaw</li>
			<li>CCDevelopment_LasPlagas_TransformBlade</li>
		</abilities>
		<biostatMet>10</biostatMet>
	</GeneDef>
	
	<GeneDef>
		<defName>CCDevelopment_LasPlagas_DominantPlaga_Gene</defName>
		<label>dominant Plaga</label>
		<description>Plaga Parasites of the dominant species allow the host to assume monstrous forms. Furthermore, they are abled to directly transmit commands to other parasite, thereby increasing their efficiency.</description>
		<descriptionHyperlinks>
			<AbilityDef>CCDevelopment_LasPlagas_TransformClaw</AbilityDef>
			<AbilityDef>CCDevelopment_LasPlagas_TransformBlade</AbilityDef>
			<AbilityDef>CCDevelopment_LasPlagas_WorkDrive</AbilityDef>
			<AbilityDef>CCDevelopment_LasPlagas_CombatCommand</AbilityDef>
			<AbilityDef>CCDevelopment_LasPlagas_Convert</AbilityDef>
		</descriptionHyperlinks>
		<iconPath>UI/Icons/Genes/Gene_Dominant</iconPath>
		<geneClass>CCDevelopment.LasPlagas.Gene_Dominant</geneClass>
		<statFactors>
			<SocialImpact>1.25</SocialImpact>
		</statFactors>
		<abilities>
			<li>CCDevelopment_LasPlagas_TransformClaw</li>
			<li>CCDevelopment_LasPlagas_TransformBlade</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">CCDevelopment_LasPlagas_WorkDrive</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">CCDevelopment_LasPlagas_CombatCommand</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">CCDevelopment_LasPlagas_Convert</li>
		</abilities>
		<biostatMet>10</biostatMet>
	</GeneDef>
</Defs>