	<HediffDef ParentName="AddedBodyPartBase">
		<defName>CCDevelopment_LasPlagas_ClawArm</defName>
		<label>claw arm</label>
		<description>A massive claw grown by the Plaga parasite in place of the host's arm. Incapable of any fine manipulation, but devastating in close combat.</description>
		<descriptionHyperlinks>
			<ThingDef>CCDevelopment_LasPlagas_Embryo_Superior</ThingDef>
		</descriptionHyperlinks>
		<addedPartProps>
			<partEfficiency>1</partEfficiency>
		</addedPartProps>
		<abilities>
			<li>CCDevelopment_LasPlagas_RetractTransformedArms</li>
		</abilities>
		<stages>
			<li>
				<statFactors>
					<IncomingDamageFactor>0.5</IncomingDamageFactor>
				</statFactors>
				<capMods>
					<li>
						<capacity>Manipulation</capacity>
						<offset>-0.5</offset>
					</li>
				</capMods>
			</li>
		</stages>
		<comps>
		  <li Class="HediffCompProperties_VerbGiver">
			<tools>
			  <li>
				<label>fist</label>
				<capacities>
				  <li>Scratch</li>
				  <li>Blunt</li>
				</capacities>
				<power>30</power>
				<armorPenetration>0.5</armorPenetration>
				<cooldownTime>3</cooldownTime>
				<soundMeleeHit>MeleeHit_BionicPunch</soundMeleeHit>
				<soundMeleeMiss>MeleeMiss_BionicPunch</soundMeleeMiss>
			  </li>
			</tools>
		  </li>
		</comps>
		<renderNodeProperties>
		  <li Class="PawnRenderNodeProperties_Spastic">
			<texPaths>
			  <li>Things/Pawns/Arms/Krauser_Arm_Claw</li>
			</texPaths>
			<parentTagDef>Body</parentTagDef>
			<overrideMeshSize>1</overrideMeshSize>
			<drawSize>1.5</drawSize>
			<rotDrawMode>Fresh, Rotting</rotDrawMode>
			<useSkinShader>true</useSkinShader>
			<useRottenColor>true</useRottenColor>
			<rotationRange>-10~10</rotationRange>
			<durationTicksRange>10~35</durationTicksRange>
			<nextSpasmTicksRange>10~50</nextSpasmTicksRange>
			<drawData>
			  <scaleOffsetByBodySize>true</scaleOffsetByBodySize>
			  <useBodyPartAnchor>true</useBodyPartAnchor>
			  <childScale>0.7</childScale>
			  <bodyTypeScales>
				<Hulk>1.2</Hulk>
				<Fat>1.2</Fat>
				<Thin>0.8</Thin>
			  </bodyTypeScales>
			  <defaultData>
				<layer>49</layer>
			  </defaultData>
			  <dataNorth>
				<rotationOffset>0</rotationOffset>
				<flip>true</flip>
				<layer>0</layer>
			  </dataNorth>
			  <dataEast>
				<rotationOffset>270</rotationOffset>
			  </dataEast>
			  <dataSouth>
				<rotationOffset>180</rotationOffset>
			  </dataSouth>
			  <dataWest>
				<rotationOffset>270</rotationOffset>
			  </dataWest>
			</drawData>
		  </li>
		</renderNodeProperties>
	</HediffDef>
	
