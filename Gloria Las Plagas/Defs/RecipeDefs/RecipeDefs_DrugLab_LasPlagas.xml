<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<RecipeDef>
		<defName>CCDevelopment_LasPlagas_ExtractParasite</defName>
		<label>extract las Plagas Parasite</label>
		<description>Some amber deposits contain living Plaga Parasites preserved for eons. A careful extraction can yield a dormant specimen, ready for implantation.</description>
		<jobString>Extracting Plaga Parasite</jobString>
		<recipeUsers>
			<li>DrugLab</li>
		</recipeUsers>
		<workAmount>400</workAmount>
		<workSpeedStat>DrugSynthesisSpeed</workSpeedStat>
		<workSkill>Intellectual</workSkill>
		<effectWorking>Cook</effectWorking>
		<soundWorking>Recipe_CookMeal</soundWorking>
		<skillRequirements>
			<Medicine>6</Medicine>
		</skillRequirements>
		<researchPrerequisite>MedicineProduction</researchPrerequisite>
		 <ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>CCDevelopment_LasPlagas_Amber</li>
					</thingDefs>
				</filter>
				<count>5</count>
			</li>
		</ingredients>
		
		<fixedIngredientFilter>
			<thingDefs>
				<li>CCDevelopment_LasPlagas_Amber</li>
			</thingDefs>
		</fixedIngredientFilter>
		
		
		<products>
			<CCDevelopment_LasPlagas_Embryo>1</CCDevelopment_LasPlagas_Embryo>
		</products>
	</RecipeDef>
	
	<RecipeDef>
		<defName>CCDevelopment_LasPlagas_ExtractParasite_Superior</defName>
		<label>extract las Plagas Parasite (Superior Species)</label>
		<description>Occasionally, amber yields a rarer Plaga Parasite of the superior Species. These specimens are significantly more potent than the subordinate Species but also far more dangerous for the host.</description>
		<jobString>Extracting Plaga Parasite</jobString>
		<recipeUsers>
			<li>DrugLab</li>
		</recipeUsers>
		<workAmount>1200</workAmount>
		<workSpeedStat>DrugSynthesisSpeed</workSpeedStat>
		<workSkill>Intellectual</workSkill>
		<effectWorking>Cook</effectWorking>
		<soundWorking>Recipe_CookMeal</soundWorking>
		<skillRequirements>
			<Medicine>12</Medicine>
		</skillRequirements>
		<researchPrerequisite>MedicineProduction</researchPrerequisite>
		 <ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>CCDevelopment_LasPlagas_Amber</li>
					</thingDefs>
				</filter>
				<count>25</count>
			</li>
		</ingredients>
		
		<fixedIngredientFilter>
			<thingDefs>
				<li>CCDevelopment_LasPlagas_Amber</li>
			</thingDefs>
		</fixedIngredientFilter>	
		<products>
			<CCDevelopment_LasPlagas_Embryo_Superior>1</CCDevelopment_LasPlagas_Embryo_Superior>
		</products>
	</RecipeDef>
</Defs>