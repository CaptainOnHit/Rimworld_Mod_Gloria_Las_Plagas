<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<GeneDef>
		<defName>CCDevelopment_LasPlagas_GanadoPlaga_Gene</defName>
		<label>ganado Plaga</label>
		<description>A human host fully infected by a Plaga Parasite of the subordinate species in its first stage of development. Ganados exhibit increased physical strength, though their capacity for fine motor skills and craftsmanship is noticeably diminished. They act entirely in service of the parasite's will.</description>
		<descriptionHyperlinks>
			<HediffDef>CCDevelopment_LasPlagas_LasPlagasParasite_Subordinate_Tier0</HediffDef>
		</descriptionHyperlinks>
		<geneClass>CCDevelopment.LasPlagas.Gene_Ganado</geneClass>
		<iconPath>UI/Icons/Genes/Gene_Ganado</iconPath>
	</GeneDef>

	<GeneDef>
		<defName>CCDevelopment_LasPlagas_Guadana_Head_Gene</defName>
		<label>guadana hosted head</label>
		<description>The Plaga Parasite has Burst through the host's skull.</description>
		<descriptionHyperlinks>
			<HediffDef>CCDevelopment_LasPlagas_GuadanaHead</HediffDef>
		</descriptionHyperlinks>
		 <iconPath>UI/Icons/Genes/Gene_Guadana</iconPath>
		<forcedHeadTypes><li>CCDevelopment_LasPlagas_Guadana</li></forcedHeadTypes>
		<geneClass>CCDevelopment.LasPlagas.Gene_GuanadaHead</geneClass>
		<hairTagFilter>
			<whitelist>true</whitelist>
			<tags>
				<li>Bald</li>
			</tags>
		</hairTagFilter>
		<beardTagFilter>
			<whitelist>true</whitelist>
			<tags>
				<li>NoBeard</li>
			</tags>
		</beardTagFilter>
	</GeneDef>
	
	<GeneDef>
		<defName>CCDevelopment_LasPlagas_Mandibula_Head_Gene</defName>
