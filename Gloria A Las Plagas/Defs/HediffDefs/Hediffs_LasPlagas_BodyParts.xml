			  <childScale>0.7</childScale>
			  <bodyTypeScales>
				<Hulk>1.2</Hulk>
				<Fat>1.2</Fat>
				<Thin>0.8</Thin>
			  </bodyTypeScales>
			  <defaultData>
				<layer>49</layer>
			  </defaultData>
			  <dataNorth>
				<rotationOffset>0</rotationOffset>
				<flip>true</flip>
				<layer>60</layer>
			  </dataNorth>
			  <dataEast>
				<rotationOffset>270</rotationOffset>
				<layer>60</layer>
			  </dataEast>
			  <dataSouth>
				<rotationOffset>180</rotationOffset>
			  </dataSouth>
			  <dataWest>
				<rotationOffset>270</rotationOffset>
				<layer>60</layer>
			  </dataWest>
			</drawData>
		  </li>
		</renderNodeProperties>
	</HediffDef>
	
	<HediffDef ParentName="AddedBodyPartBase">
		<defName>CCDevelopment_LasPlagas_CrippledArm</defName>
		<label>crippled arm</label>
		<description>This arm has been permanently mangled in the transformation process, it does not work as well as it once did.</description>
		<descriptionHyperlinks>
			<HediffDef>CCDevelopment_LasPlagas_BladeArm</HediffDef>
			<HediffDef>CCDevelopment_LasPlagas_ClawArm</HediffDef>
		</descriptionHyperlinks>
		<addedPartProps>
			<partEfficiency>1</partEfficiency>
		</addedPartProps>
		<stages>
			<li>
				<capMods>
					<li>
						<capacity>Manipulation</capacity>
						<offset>-0.2</offset>
					</li>
				</capMods>
			</li>
		</stages>
	</HediffDef>
</Defs>